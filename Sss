local function takeQuest(arg1)
    if not ScriptActive then return false end
    
    stopAttack()
    task.wait(0.2)
    
    if statusText then
        statusText.Text = "📜 Taking quest from " .. arg1["NPC"]
    end
    
    local args = {
        [1] = "EndDialogue",
        [2] = arg1
    }
    
    game:GetService("Players").LocalPlayer.Character.RemoteEvent:FireServer(unpack(args))
    
    task.wait(2)
    
    if statusText then
        statusText.Text = "✅ Quest taken from " .. arg1["NPC"]
    end
    
    return true
end

local function startStandFarming()
    while ScriptActive do
        local stats = player:FindFirstChild("PlayerStats")
        if not stats then task.wait(2) continue end
        
        local standVal = stats:FindFirstChild("Stand")
        if not standVal then task.wait(2) continue end
        
        local currentStand = standVal.Value

        if currentStand ~= "None" then
            if unwantedStands[currentStand] then
                if statusText then
                    statusText.Text = "🔄 Bad stand, resetting..."
                end
                local hasRoka = player.Backpack:FindFirstChild("Rokakaka") or (player.Character and player.Character:FindFirstChild("Rokakaka"))
                
                if not hasRoka then
                    farmItem("Rokakaka")
                end
                useItem("Rokakaka")
                
                local elapsed = 0
                while standVal.Value ~= "None" and elapsed < 20 and ScriptActive do
                    task.wait(1)
                    elapsed = elapsed + 1
                end
                task.wait(4)
            else
                if statusText then
                    statusText.Text = "✅ Good stand: " .. currentStand
                end
                toggleStand()
                
                if statusText then
                    statusText.Text = "🔄 Resetting character to fix stand summon..."
                end
                
                local humanoid = character:FindFirstChild("Humanoid")
                if humanoid then
                    humanoid.Health = 0
                end
                stopAttack()
                
                character = player.CharacterAdded:Wait()
                rootPart = character:WaitForChild("HumanoidRootPart")
                RE = character:WaitForChild("RemoteEvent")
                RF = character:WaitForChild("RemoteFunction")
                
                local respawnAttempts = 0
                local respawnSuccess = false
                
                while not respawnSuccess and ScriptActive do
                    respawnAttempts = respawnAttempts + 1
                    if statusText then
                        statusText.Text = "🔄 Summoning stand after respawn (attempt " .. respawnAttempts .. ")..."
                    end
                    
                    toggleStand()
                    task.wait(2)
                    
                    if hasStand() then
                        respawnSuccess = true
                        if statusText then
                            statusText.Text = "✅ Stand summoned successfully after respawn!"
                        end
                    else
                        if statusText then
                            statusText.Text = "⚠️ Failed to summon after respawn, retrying..."
                        end
                        task.wait(1)
                    end
                end
                
                if not respawnSuccess then
                    if statusText then
                        statusText.Text = "❌ Cannot summon stand after respawn, giving up..."
                    end
                    return nil
                end
                
                if statusText then
                    statusText.Text = "✅ Character respawned, ready to use stand!"
                end
                
                return currentStand
            end
        else
            if statusText then
                statusText.Text = "📚 Learning skills..."
            end
            learnSkills()
            
            local hasArrow = player.Backpack:FindFirstChild("Mysterious Arrow") or (player.Character and player.Character:FindFirstChild("Mysterious Arrow"))
            
            if not hasArrow then
                if statusText then
                    statusText.Text = "🏹 Farming arrow..."
                end
                farmItem("Mysterious Arrow")
            end
            if statusText then
                statusText.Text = "✨ Using arrow..."
            end
            useItem("Mysterious Arrow")
            
            local elapsed = 0
            while standVal.Value == "None" and elapsed < 30 and ScriptActive do
                task.wait(1)
                elapsed = elapsed + 1
            end
            task.wait(2)
        end
        task.wait(2)
    end
end

local function myFarmLogic()
    local prestige = getPrestige()
    if prestige == 0 then
        takeQuest({
            ["NPC"] = "Giorno",
            ["Option"] = "Option2",
            ["Dialogue"] = "Dialogue3"
        })
        
