local function stopFarming()
    ScriptActive = false
    stopAttack()
    stopStandFarm()
    if statusText then
        statusText.Text = "Status: STOPPED"
    end
    if farmingCoroutine then
        coroutine.close(farmingCoroutine)
        farmingCoroutine = nil
    end
end

local function startFarming()
    if ScriptActive then return end
    ScriptActive = true
    if statusText then
        statusText.Text = "Status: RUNNING..."
    end
    
    farmingCoroutine = coroutine.create(function()
        local success, err = pcall(myFarmLogic)
        if not success then
            if statusText then
                statusText.Text = "Status: ERROR"
            end
            warn("Farm error:", err)
        end
        ScriptActive = false
        stopAttack()
        stopStandFarm()
        if statusText then
            statusText.Text = "Status: IDLE"
        end
        toggleBtn.BackgroundColor3 = Color3.fromRGB(76, 175, 80)
        toggleBtn.Text = "▶ START FARM"
    end)
    coroutine.resume(farmingCoroutine)
end

toggleBtn.MouseButton1Click:Connect(function()
    if ScriptActive then
        stopFarming()
        toggleBtn.BackgroundColor3 = Color3.fromRGB(76, 175, 80)
        toggleBtn.Text = "▶ START FARM"
    else
        startFarming()
        toggleBtn.BackgroundColor3 = Color3.fromRGB(244, 67, 54)
        toggleBtn.Text = "⏹ STOP FARM"
    end
end)

