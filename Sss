-- ========== ОПРЕДЕЛЕНИЕ УСТРОЙСТВА ==========
local deviceType = "PC"
local VirtualInputManager = nil
local pcModeAvailable = false

local function detectDevice()
    local uis = UserInputService
    
    if uis.TouchEnabled then
        deviceType = "Mobile"
    elseif uis.GamepadEnabled and not uis.TouchEnabled then
        deviceType = "Console"
    else
        deviceType = "PC"
    end
    
    if deviceType == "PC" then
        local success, VIM = pcall(function()
            return game:GetService("VirtualInputManager")
        end)
        if success and VIM then
            VirtualInputManager = VIM
            pcModeAvailable = true
        end
    end
    
    print("[Device] " .. deviceType .. " - " .. (pcModeAvailable and "Auto-click available" or "Manual mode"))
    return deviceType
end

detectDevice()

-- ========== ФУНКЦИЯ ОЖИДАНИЯ ДИАЛОГА ==========
local function waitForDialogueToEnd(textLabel)
    if not textLabel then return end
    
    local lastText = ""
    local timer = 0
    local checkInterval = 0.2
    local settleTime = 1.0
    
    while true do
        local currentText = textLabel.Text
        
        if currentText ~= lastText and currentText ~= "" then
            lastText = currentText
            timer = 0
        else
            timer = timer + checkInterval
        end
        
        if timer >= settleTime and currentText ~= "" then
            break
        end
        
        task.wait(checkInterval)
    end
end

-- ========== ЭМУЛЯЦИЯ КЛИКА ДЛЯ ПК ==========
local function pcClick(button)
    if not button or not pcModeAvailable then return false end
    
    GuiService.SelectedObject = button
    task.wait(0.1)
    
    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Return, false, game)
    task.wait(0.05)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Return, false, game)
    
    task.wait(0.1)
    GuiService.SelectedObject = nil
    
    return true
end

-- ========== ЭМУЛЯЦИЯ КАСАНИЯ ДЛЯ ТЕЛЕФОНА ==========
local function mobileTap(button)
    if not button then return false end
    
    -- Получаем абсолютные координаты кнопки
    local absPos = button.AbsolutePosition
    local absSize = button.AbsoluteSize
    
    if absPos.X == 0 and absPos.Y == 0 then
        -- Кнопка ещё не отрендерена, пробуем другой метод
        GuiService.SelectedObject = button
        task.wait(0.1)
        
        -- Имитируем касание через UserInputService
        local centerX = absPos.X + absSize.X / 2
        local centerY = absPos.Y + absSize.Y / 2
        
        if centerX > 0 and centerY > 0 then
            local touchPos = Vector2.new(centerX, centerY)
            
            -- Эмулируем начало касания
            pcall(function()
                UserInputService:SetTouchEnabled(true)
            end)
            
            -- Отправляем событие касания
            local touchInput = Instance.new("InputObject")
            touchInput.UserInputType = Enum.UserInputType.Touch
            touchInput.Position = touchPos
            touchInput.Delta = Vector2.new(0, 0)
            
            -- Нажатие
            pcall(function()
                UserInputService:FireTouchEvent(touchInput)
            end)
            
            task.wait(0.1)
            
            -- Отпускание
            touchInput.UserInputState = Enum.UserInputState.End
            pcall(function()
                UserInputService:FireTouchEvent(touchInput)
            end)
        end
    else
        -- Визуальный эффект нажатия
        local originalSize = button.Size
        local originalColor = button.BackgroundColor3
        
        button.Size = originalSize - UDim2.new(0, 4, 0, 4)
        button.BackgroundColor3 = Color3.fromRGB(200, 200, 200)
        
        task.wait(0.05)
        
        button.Size = originalSize
        button.BackgroundColor3 = originalColor
    end
    
    task.wait(0.1)
    GuiService.SelectedObject = nil
    
    return true
end

-- ========== УНИВЕРСАЛЬНАЯ ФУНКЦИЯ ДЛЯ ИСПОЛЬЗОВАНИЯ ПРЕДМЕТОВ ==========
-- ========== УНИВЕРСАЛЬНАЯ ФУНКЦИЯ ДЛЯ ИСПОЛЬЗОВАНИЯ ПРЕДМЕТОВ ==========
local function useItemThroughGUI(itemName)
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid then 
        updateStatus("❌ Humanoid not found!")
        return false 
    end
    
    -- Ищем предмет в инвентаре
    local tool = character:FindFirstChild(itemName) or backpack:FindFirstChild(itemName)
    
    if not tool then
        updateStatus("❌ " .. itemName .. " not found in inventory!")
        return false
    end
    
    updateStatus("📦 Equipping " .. itemName .. "...")
    
    -- Если предмет в рюкзаке - экипируем
    if tool.Parent == backpack then
        -- Метод 1: через Humanoid
        local success = pcall(function()
            humanoid:EquipTool(tool)
        end)
        
        if not success then
            -- Метод 2: просто перемещаем в персонажа
            pcall(function()
                tool.Parent = character
            end)
        end
        
        task.wait(0.5)
        
        -- Проверяем, экипирован ли предмет
        local equippedTool = character:FindFirstChild(itemName)
        if not equippedTool then
            updateStatus("⚠️ Failed to equip " .. itemName .. ", trying again...")
            pcall(function()
                tool.Parent = character
            end)
            task.wait(0.5)
        end
    end
    
    -- Ещё раз проверяем, что предмет в персонаже
    local finalTool = character:FindFirstChild(itemName)
    if not finalTool then
        updateStatus("❌ Cannot equip " .. itemName)
        return false
    end
    
    updateStatus("✨ Activating " .. itemName .. "...")
    
    -- Активируем предмет
    pcall(function()
        finalTool:Activate()
    end)
    
    task.wait(1) -- Даем время на открытие GUI
    
    -- Ищем GUI диалога
    local dialogueGui = player.PlayerGui:FindFirstChild("DialogueGui")
    if not dialogueGui then
        for i = 1, 10 do
            dialogueGui = player.PlayerGui:FindFirstChild("DialogueGui")
            if dialogueGui then break end
            task.wait(0.5)
        end
    end
    
    if dialogueGui then
        updateStatus("💬 Dialogue GUI found, interacting...")
        
        local frame = dialogueGui:FindFirstChild("Frame")
        if frame then
            local options = frame:FindFirstChild("Options")
            if options then
                local opt1 = options:FindFirstChild("Option1")
                local opt2 = options:FindFirstChild("Option2")
                
                if opt1 and opt2 then
                    local button = opt1:FindFirstChild("TextButton")
                    local textLabel = opt2:FindFirstChild("TextButton") or opt2
                    
                    if button and textLabel then
                        -- Ждем появления текста
                        local waitStart = tick()
                        while textLabel.Text == "" and tick() - waitStart < 5 do
                            task.wait(0.2)
                        end
                        
                        updateStatus("💬 Dialogue text loaded, clicking...")
                        waitForDialogueToEnd(textLabel)
                        
                        -- Выбираем метод клика в зависимости от устройства
                        local clickSuccess = false
                        
                        if deviceType == "PC" and pcModeAvailable then
                            clickSuccess = pcClick(button)
                        elseif deviceType == "Mobile" then
                            clickSuccess = mobileTap(button)
                        end
                        
                        -- Дополнительная попытка через fireclickdetector если есть
                        if not clickSuccess then
                            local clickDetector = button:FindFirstChildOfClass("ClickDetector")
                            if clickDetector then
                                pcall(function()
                                    fireclickdetector(clickDetector)
                                end)
                                clickSuccess = true
                            end
                        end
                        
                        if clickSuccess then
                            updateStatus("✅ " .. itemName .. " used successfully!")
                            task.wait(1)
                            return true
                        end
                    end
                end
            end
        end
    else
        updateStatus("⚠️ Dialogue GUI not found for " .. itemName)
        -- Возможно GUI еще не появился, ждем подольше
        for i = 1, 15 do
            dialogueGui = player.PlayerGui:FindFirstChild("DialogueGui")
            if dialogueGui then
                updateStatus("💬 Dialogue GUI appeared after delay!")
                break
            end
            task.wait(0.5)
        end
    end
    
    updateStatus("⚠️ Failed to complete " .. itemName .. " interaction")
    return false
end

-- ========== ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ ==========

local function getCharacter()
    local char = player.Character or player.CharacterAdded:Wait()
    local root = char:WaitForChild("HumanoidRootPart")
    return char, root
end

local function travelTo(targetPosition)
    if not rootPart or not rootPart.Parent then return false end
    
    local startPosition = rootPart.Position
    local direction = (targetPosition - startPosition)
    local distance = direction.Magnitude
    local chunkSize = 50
    local numChunks = math.max(1, math.ceil(distance / chunkSize))
    local stepVector = direction / numChunks
    
    for i = 1, numChunks do
        if not ScriptActive or not rootPart or not rootPart.Parent then
            return false
        end
        local newPosition = rootPart.Position + stepVector
        rootPart.CFrame = CFrame.new(newPosition)
        task.wait(0.05)
    end
    
    rootPart.CFrame = CFrame.new(targetPosition)
    task.wait(0.05)
    return true
end

local function findAliveNPC(targetName)
    local liv = Workspace:FindFirstChild("Living")
    if not liv then return nil end
    
    for _, npc in pairs(liv:GetChildren()) do
        if npc.Name == targetName then
            local hrp = npc:FindFirstChild("HumanoidRootPart")
            local healthValue = npc:FindFirstChild("Health")
            
            if hrp and healthValue and healthValue.Value > 0 then
                return npc
            end
        end
    end
    return nil
end

local function getPrestige()
    local prestige = game:GetService("Players").LocalPlayer.PlayerStats.Prestige.Value
    return prestige
end

local function learnSkills()
    local char, _ = getCharacter()
    local RF_local = char:WaitForChild("RemoteFunction")
    for _, data in ipairs(skills) do
        pcall(function() RF_local:InvokeServer("LearnSkill", data) end)
    end
end

local function triggerProximityPrompt(prompt)
    if not prompt or not prompt.Parent then return false end
    
    local originalHoldDuration = prompt.HoldDuration
    local originalRequiresLineOfSight = prompt.RequiresLineOfSight
    
    prompt.HoldDuration = 0
    prompt.RequiresLineOfSight = false
    
    local success = pcall(function()
        fireproximityprompt(prompt)
    end)
    
    task.wait(0.1)
    prompt.HoldDuration = originalHoldDuration
    prompt.RequiresLineOfSight = originalRequiresLineOfSight
    
    return success
end

local function farmItem(itemName)
    while task.wait(0.5) and ScriptActive do
        local hasItem = player.Backpack:FindFirstChild(itemName) or (player.Character and player.Character:FindFirstChild(itemName))
        if hasItem then
            return true
        end

        local itemsFolder = Workspace:FindFirstChild("Item_Spawns")
        if itemsFolder then itemsFolder = itemsFolder:FindFirstChild("Items") end
        
        if itemsFolder then
            for _, model in ipairs(itemsFolder:GetDescendants()) do
                if (model:IsA("Model") or model:IsA("BasePart")) and not model:IsA("Tool") then
                    local prompt = model:FindFirstChildOfClass("ProximityPrompt")
                    if prompt and prompt.ObjectText == itemName then
                        local part = model.PrimaryPart or model:FindFirstChildOfClass("BasePart") or model
                        if part:IsA("BasePart") then
                            local targetPos = part.Position + Vector3.new(0, 2, 0)
                            if travelTo(targetPos) then
                                task.wait(0.2)
                                triggerProximityPrompt(prompt)
                                task.wait(1)
                                break
                            end
                        end
                    end
                end
            end
        end
    end
end

