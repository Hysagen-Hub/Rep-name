local function getCharacter()
    local char = player.Character or player.CharacterAdded:Wait()
    local root = char:WaitForChild("HumanoidRootPart")
    return char, root
end

local function travelTo(targetPosition)
    if not rootPart or not rootPart.Parent then return false end
    
    local startPosition = rootPart.Position
    local direction = (targetPosition - startPosition)
    local distance = direction.Magnitude
    local chunkSize = 50
    local numChunks = math.max(1, math.ceil(distance / chunkSize))
    local stepVector = direction / numChunks
    
    for i = 1, numChunks do
        if not ScriptActive or not rootPart or not rootPart.Parent then
            return false
        end
        local newPosition = rootPart.Position + stepVector
        rootPart.CFrame = CFrame.new(newPosition)
        task.wait(0.05)
    end
    
    rootPart.CFrame = CFrame.new(targetPosition)
    task.wait(0.05)
    return true
end

local function findAliveNPC(targetName)
    local liv = Workspace:FindFirstChild("Living")
    if not liv then return nil end
    
    for _, npc in pairs(liv:GetChildren()) do
        if npc.Name == targetName then
            local hrp = npc:FindFirstChild("HumanoidRootPart")
            local healthValue = npc:FindFirstChild("Health")
            
            if hrp and healthValue and healthValue.Value > 0 then
                return npc
            end
        end
    end
    return nil
end

local function getPrestige()
    local prestige = game:GetService("Players").LocalPlayer.PlayerStats.Prestige.Value
    return prestige
end

local function learnSkills()
    local char, _ = getCharacter()
    local RF_local = char:WaitForChild("RemoteFunction")
    for _, data in ipairs(skills) do
        pcall(function() RF_local:InvokeServer("LearnSkill", data) end)
    end
end

local function triggerProximityPrompt(prompt)
    if not prompt or not prompt.Parent then return false end
    
    local originalHoldDuration = prompt.HoldDuration
    local originalRequiresLineOfSight = prompt.RequiresLineOfSight
    
    prompt.HoldDuration = 0
    prompt.RequiresLineOfSight = false
    
    local success = pcall(function()
        fireproximityprompt(prompt)
    end)
    
    task.wait(0.1)
    prompt.HoldDuration = originalHoldDuration
    prompt.RequiresLineOfSight = originalRequiresLineOfSight
    
    return success
end

local function clickScreenCenter()
    local screenSize = camera.ViewportSize
    local centerX = screenSize.X / 2
    local centerY = screenSize.Y / 2
    
    local VirtualInputManager = game:GetService("VirtualInputManager")
    VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, true, game, 0)
    task.spawn(function()
        task.wait(0.05)
        VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, false, game, 0)
    end)
end

local function clickGuiButton(button)
    if not button or not button.Visible then return false end
    local inset = GuiService:GetGuiInset()
    local centerX = button.AbsolutePosition.X + (button.AbsoluteSize.X / 2) + inset.X
    local heightOffset = button.AbsoluteSize.Y * 1.4
    local centerY = button.AbsolutePosition.Y + (button.AbsoluteSize.Y / 2) + inset.Y - heightOffset
    
    local VirtualInputManager = game:GetService("VirtualInputManager")
    VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, true, game, 0)
    task.spawn(function()
        task.wait(0.05)
        VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, false, game, 0)
    end)
    return true
end

local function findDialogueOptionButton(dialogueGui)
    local options = dialogueGui:FindFirstChild("Options")
    if options then
        local option1 = options:FindFirstChild("Option1")
        if option1 then
            local button = option1:FindFirstChildWhichIsA("GuiButton")
            if button and button.Visible then return button end
        end
    end
    for _, child in pairs(dialogueGui:GetDescendants()) do
        if (child:IsA("TextButton") or child:IsA("ImageButton")) and child.Visible and child.Active then
            return child
        end
    end
    return nil
end

local function equipItem(itemName)
    local backpack = player:WaitForChild("Backpack")
    local item = backpack:FindFirstChild(itemName)
    
    if item then
        local char, _ = getCharacter()
        item.Parent = char
        return true
    end
    return false
end

local function farmItem(itemName)
    while task.wait(0.5) and ScriptActive do
        local hasItem = player.Backpack:FindFirstChild(itemName) or (player.Character and player.Character:FindFirstChild(itemName))
        if hasItem then
            return true
        end

        local itemsFolder = Workspace:FindFirstChild("Item_Spawns")
        if itemsFolder then itemsFolder = itemsFolder:FindFirstChild("Items") end
        
        if itemsFolder then
            for _, model in ipairs(itemsFolder:GetDescendants()) do
                if (model:IsA("Model") or model:IsA("BasePart")) and not model:IsA("Tool") then
                    local prompt = model:FindFirstChildOfClass("ProximityPrompt")
                    if prompt and prompt.ObjectText == itemName then
                        local part = model.PrimaryPart or model:FindFirstChildOfClass("BasePart") or model
                        if part:IsA("BasePart") then
                            local targetPos = part.Position + Vector3.new(0, 2, 0)
                            if travelTo(targetPos) then
                                task.wait(0.2)
                                triggerProximityPrompt(prompt)
                                task.wait(1)
                                break
                            end
                        end
                    end
                end
            end
        end
    end
end

local function useItem(itemName)
    if not equipItem(itemName) then return false end
    task.wait(0.5)

    local playerGui = player:WaitForChild("PlayerGui")
    local dialogueGui = nil
    while not dialogueGui and ScriptActive do
        clickScreenCenter()
        dialogueGui = playerGui:FindFirstChild("DialogueGui")
        if not dialogueGui then
            for _, gui in pairs(playerGui:GetChildren()) do
                if gui.Name:lower():find("dialogue") then
                    dialogueGui = gui
                    break
                end
            end
        end
        task.wait(0.5)
    end

    local targetButton = nil
    while not targetButton and ScriptActive do
        targetButton = findDialogueOptionButton(dialogueGui)
        if targetButton then
            clickGuiButton(targetButton)
            task.wait(0.1)
            clickGuiButton(targetButton)
            break
        end
        task.wait(0.5)
    end

    while dialogueGui and dialogueGui.Parent == playerGui and ScriptActive do
        targetButton = findDialogueOptionButton(dialogueGui)
        if targetButton then
            clickGuiButton(targetButton)
        end
        task.wait(0.5)
    end

    task.wait(5)
end

local function startAttack()
    if isAttacking then return end
    isAttacking = true
    
    attackThread = task.spawn(function()
        local attackTable = {Bool = true, Type = "m1"}
        while isAttacking and ScriptActive do
            RE:FireServer("HoldAttack", attackTable)
            task.wait(0.1)
        end
    end)
end

local function stopAttack()
    if not isAttacking then return end
    isAttacking = false
    
    if attackThread then
        task.cancel(attackThread)
        attackThread = nil
    end
    
    local attackTable = {Bool = false, Type = "m1"}
    RE:FireServer("HoldAttack", attackTable)
end

local function toggleStand()
    stopAttack()
    task.wait(0.2)
    
    pcall(function()
        RF:InvokeServer("ToggleStand", "Toggle")
    end)
    
    task.wait(0.5)
end

local function hasStand()
    local stats = player:FindFirstChild("PlayerStats")
    if stats and stats:FindFirstChild("Stand") then
        return stats.Stand.Value ~= "None"
    end
    return false
end

local function getStandMorph()
    if character then
        return character:FindFirstChild("StandMorph")
    end
    return nil
end

local function attachStandToTarget(target)
    local standMorph = getStandMorph()
    if not standMorph or not target then return end
    
    local targetRoot = target:FindFirstChild("HumanoidRootPart")
    if not targetRoot then return end
    
    local standPosition = targetRoot.Position - targetRoot.CFrame.LookVector * 3
    local standCFrame = CFrame.new(standPosition)
    
    standMorph:SetPrimaryPartCFrame(standCFrame)
end

local function updateStatus(msg)
    print("[Mista]", msg)
    if statusText then
        statusText.Text = msg
    end
end

local function updatePlayerPositionBehind(npc, distance)
    if not npc or not npc.Parent then return false end
    
    local targetRoot = npc:FindFirstChild("HumanoidRootPart")
    if not targetRoot then return false end
    
    if not rootPart or not rootPart.Parent then return false end
    
    local behindPosition = targetRoot.Position - targetRoot.CFrame.LookVector * distance
    
    rootPart.CFrame = CFrame.new(behindPosition)
    rootPart.CFrame = CFrame.lookAt(rootPart.Position, targetRoot.Position)
    
    return true
end

local function updatePlayerPositionAbove(npc, height)
    if not npc or not npc.Parent then return false end
    
    local targetHead = npc:FindFirstChild("Head")
    if not targetHead then return false end
    
    if not rootPart or not rootPart.Parent then return false end
    
    local abovePosition = targetHead.Position + Vector3.new(0, height, 0)
    
    rootPart.CFrame = CFrame.new(abovePosition)
    
    return true
end

local function stopHeartbeat()
    if heartbeatConnection then
        heartbeatConnection:Disconnect()
        heartbeatConnection = nil
    end
end

local function stopStandFarm()
    standFarmMode = false
    currentTarget = nil
    stopHeartbeat()
    stopAttack()
end

local function killLogicNormal(npc)
    if not npc or not npc.Parent then return false end
    
    stopHeartbeat()
    startAttack()
    
    heartbeatConnection = RunService.Heartbeat:Connect(function()
        if not ScriptActive or standFarmMode or not npc or not npc.Parent then
            return
        end
        
        if not character or not character:FindFirstChild("Humanoid") or character.Humanoid.Health <= 0 then
            return
        end
        
        updatePlayerPositionBehind(npc, 4)
    end)
    
    local startTime = tick()
    local npcDied = false
    
    while ScriptActive and not standFarmMode and npc and npc.Parent do
        local currentHealth = npc:FindFirstChild("Health")
        if not currentHealth or currentHealth.Value <= 0 then
            npcDied = true
            break
        end
        
        if not character or not character:FindFirstChild("Humanoid") or character.Humanoid.Health <= 0 then
            break
        end
        
        task.wait(0.1)
        
        if tick() - startTime > 30 then
            break
        end
    end
    
    stopHeartbeat()
    stopAttack()
    task.wait(0.2)
    
    return npcDied
end

local function killLogicWithStand(npc)
    if not npc or not npc.Parent then return false end
    
    local targetRoot = npc:FindFirstChild("HumanoidRootPart")
    if not targetRoot then return false end
    
    if statusText then
        statusText.Text = "⚔️ Attacking " .. npc.Name .. " with stand..."
    end
    
    stopHeartbeat()
    startAttack()
    
    local standMorph = getStandMorph()
    if standMorph then
        local standPosition = targetRoot.Position
        standMorph:SetPrimaryPartCFrame(CFrame.new(standPosition))
    end
    
    heartbeatConnection = RunService.Heartbeat:Connect(function()
        if not ScriptActive or not standFarmMode or not npc or not npc.Parent then
            return
        end
        
        if not character or not character:FindFirstChild("Humanoid") or character.Humanoid.Health <= 0 then
            return
        end
        
        local targetHead = npc:FindFirstChild("Head")
        if targetHead then
            local abovePosition = targetHead.Position + Vector3.new(0, 16, 0)
            rootPart.CFrame = CFrame.new(abovePosition)
        end
        
        local currentStand = getStandMorph()
        if currentStand and npc and npc.Parent then
            local currentTargetRoot = npc:FindFirstChild("HumanoidRootPart")
            if currentTargetRoot then
                local standPosition = currentTargetRoot.Position - currentTargetRoot.CFrame.LookVector * 3
                currentStand:SetPrimaryPartCFrame(CFrame.new(standPosition))
            end
        end
    end)
    
    local startTime = tick()
    local npcDied = false
    local lastHealth = nil
    
    while ScriptActive and standFarmMode and npc and npc.Parent do
        local currentHealth = npc:FindFirstChild("Health")
        if not currentHealth or currentHealth.Value <= 0 then
            npcDied = true
            if statusText then
                statusText.Text = "💀 " .. npc.Name .. " defeated!"
            end
            break
        end
        
        if lastHealth ~= currentHealth.Value and tick() % 1 < 0.1 then
            lastHealth = currentHealth.Value
            if statusText then
                statusText.Text = "❤️ " .. npc.Name .. " HP: " .. lastHealth
            end
        end
        
        if not character or not character:FindFirstChild("Humanoid") or character.Humanoid.Health <= 0 then
            if statusText then
                statusText.Text = "💀 Player died during combat!"
            end
            break
        end
        
        if tick() % 2 < 0.1 then
            if not hasStand() then
                if statusText then
                    statusText.Text = "⚠️ Stand lost during combat, resummoning..."
                end
                toggleStand()
                task.wait(1)
                if hasStand() then
                    local currentTargetRoot = npc:FindFirstChild("HumanoidRootPart")
                    if currentTargetRoot then
                        local newStand = getStandMorph()
                        if newStand then
                            local standPosition = currentTargetRoot.Position - currentTargetRoot.CFrame.LookVector * 3
                            newStand:SetPrimaryPartCFrame(CFrame.new(standPosition))
                        end
                    end
                end
            end
        end
        
        task.wait(0.2)
        
        if tick() - startTime > 60 then
            if statusText then
                statusText.Text = "⏰ Combat timeout for " .. npc.Name
            end
            break
        end
    end
    
    stopHeartbeat()
    stopAttack()
    task.wait(0.2)
    
    return npcDied
end

local function farmNPCs(npcName, neededCount)
    if not ScriptActive then return end
    
    local killedCount = 0
    if statusText then
        statusText.Text = "⚔️ Farming " .. npcName .. ": 0/" .. neededCount
    end
    
    while killedCount < neededCount and ScriptActive and not standFarmMode do
        if not character or not character:FindFirstChild("Humanoid") or character.Humanoid.Health <= 0 then
            if statusText then
                statusText.Text = "💀 Ожидание респавна..."
            end
            character = player.CharacterAdded:Wait()
            rootPart = character:WaitForChild("HumanoidRootPart")
            RE = character:WaitForChild("RemoteEvent")
            RF = character:WaitForChild("RemoteFunction")
            
            if ScriptActive then
                stopAttack()
                task.wait(1)
            end
            task.wait(2)
        end
        
        local target = findAliveNPC(npcName)
        
        if target then
            travelTo(target.HumanoidRootPart.Position)
            task.wait(0.3)
            
            if not ScriptActive then break end
            
            local npcDied = killLogicNormal(target)
            
            if npcDied then
                killedCount = killedCount + 1
                if statusText then
                    statusText.Text = "⚔️ Farming " .. npcName .. ": " .. killedCount .. "/" .. neededCount
                end
            end
            task.wait(0.5)
        else
            if statusText then
                statusText.Text = "⏳ Ожидание спавна: " .. npcName
            end
            task.wait(3)
        end
    end
end

local function farmWithStand(npcName, neededCount)
    if not ScriptActive then return end
    
    local killedCount = 0
    standFarmMode = true
    if statusText then
        statusText.Text = "🤖 Stand farm " .. npcName .. ": 0/" .. neededCount
    end
    
    local standMorph = nil
    local summonAttempts = 0
    
    while not standMorph and ScriptActive and standFarmMode do
        summonAttempts = summonAttempts + 1
        if statusText then
            statusText.Text = "🔄 Summoning stand (attempt " .. summonAttempts .. ")..."
        end
        
        toggleStand()
        task.wait(2)
        
        standMorph = getStandMorph()
        
        if not standMorph then
            if statusText then
                statusText.Text = "⚠️ Failed to summon stand, retrying..."
            end
            task.wait(1)
        end
    end
    
    if not standMorph then
        if statusText then
            statusText.Text = "❌ Cannot summon stand at all, stopping..."
        end
        standFarmMode = false
        return
    end
    
    if statusText then
        statusText.Text = "✅ Stand summoned successfully!"
    end
    
    if not isAttacking then
        startAttack()
    end
    
    while killedCount < neededCount and ScriptActive and standFarmMode do
        if not hasStand() then
            if statusText then
                statusText.Text = "🔄 Stand lost, resummoning..."
            end
            
            local resummonAttempts = 0
            local resummonSuccess = false
            
            while not resummonSuccess and ScriptActive and standFarmMode do
                resummonAttempts = resummonAttempts + 1
                if statusText then
                    statusText.Text = "🔄 Resummoning stand (attempt " .. resummonAttempts .. ")..."
                end
                
                toggleStand()
                task.wait(2)
                
                if hasStand() then
                    resummonSuccess = true
                    standMorph = getStandMorph()
                    if statusText then
                        statusText.Text = "✅ Stand resummoned successfully!"
                    end
                else
                    if statusText then
                        statusText.Text = "⚠️ Failed to resummon, retrying..."
                    end
                    task.wait(1)
                end
            end
            
            if not resummonSuccess then
                if statusText then
                    statusText.Text = "❌ Cannot resummon stand, stopping..."
                end
                standFarmMode = false
                break
            end
        end
        
        if not character or not character:FindFirstChild("Humanoid") or character.Humanoid.Health <= 0 then
            if statusText then
                statusText.Text = "💀 Waiting for respawn..."
            end
            character = player.CharacterAdded:Wait()
            rootPart = character:WaitForChild("HumanoidRootPart")
            RE = character:WaitForChild("RemoteEvent")
            RF = character:WaitForChild("RemoteFunction")
            
            if ScriptActive and standFarmMode then
                stopAttack()
                task.wait(0.3)
                
                local respawnSummonAttempts = 0
                local respawnSummonSuccess = false
                
                while not respawnSummonSuccess and ScriptActive and standFarmMode do
                    respawnSummonAttempts = respawnSummonAttempts + 1
                    if statusText then
                        statusText.Text = "🔄 Summoning stand after respawn (attempt " .. respawnSummonAttempts .. ")..."
                    end
                    
                    toggleStand()
                    task.wait(2)
                    
                    if hasStand() then
                        respawnSummonSuccess = true
                        standMorph = getStandMorph()
                        if statusText then
                            statusText.Text = "✅ Stand summoned after respawn!"
                        end
                    else
                        if statusText then
                            statusText.Text = "⚠️ Failed to summon after respawn, retrying..."
                        end
                        task.wait(1)
                    end
                end
                
                if not respawnSummonSuccess then
                    if statusText then
                        statusText.Text = "❌ Cannot summon stand after respawn, stopping..."
                    end
                    standFarmMode = false
                    break
                end
                
                startAttack()
                standMorph = getStandMorph()
            end
            task.wait(1)
        end
        
        local target = findAliveNPC(npcName)
        
        if target then
            currentTarget = target
            
            if statusText then
                statusText.Text = "🎯 Found " .. npcName .. ", engaging..."
            end
            
            local targetRoot = target:FindFirstChild("HumanoidRootPart")
            if targetRoot then
                travelTo(targetRoot.Position)
                task.wait(0.5)
            end
            
            local targetDied = killLogicWithStand(target)
            
            if targetDied then
                killedCount = killedCount + 1
                if statusText then
                    statusText.Text = "✅ " .. npcName .. " defeated! (" .. killedCount .. "/" .. neededCount .. ")"
                end
            else
                if statusText then
                    statusText.Text = "⚠️ Failed to defeat " .. npcName .. ", retrying..."
                end
            end
            
            task.wait(1)
        else
            if statusText then
                statusText.Text = "⏳ Waiting for " .. npcName .. " to spawn..."
            end
            task.wait(3)
        end
    end
    
    stopStandFarm()
    
    if killedCount >= neededCount and statusText then
        statusText.Text = "✅ Stand farm completed: " .. npcName
    end
end

