-- ========== ФУНКЦИИ АТАКИ ==========

local function startAttack()
    if isAttacking then return end
    isAttacking = true
    
    attackThread = task.spawn(function()
        local attackTable = {Bool = true, Type = "m1"}
        while isAttacking and ScriptActive do
            RE:FireServer("HoldAttack", attackTable)
            task.wait(0.1)
        end
    end)
end

local function stopAttack()
    if not isAttacking then return end
    isAttacking = false
    
    if attackThread then
        task.cancel(attackThread)
        attackThread = nil
    end
    
    local attackTable = {Bool = false, Type = "m1"}
    RE:FireServer("HoldAttack", attackTable)
end

-- ========== ФУНКЦИИ СТЕНДА ==========

local function toggleStand()
    stopAttack()
    task.wait(0.2)
    
    pcall(function()
        RF:InvokeServer("ToggleStand", "Toggle")
    end)
    
    task.wait(0.5)
end

local function hasStand()
    local stats = player:FindFirstChild("PlayerStats")
    if stats and stats:FindFirstChild("Stand") then
        return stats.Stand.Value ~= "None"
    end
    return false
end

local function getStandMorph()
    if character then
        return character:FindFirstChild("StandMorph")
    end
    return nil
end

local function updateStatus(msg)
    print("[Mista]", msg)
    if statusText then
        statusText.Text = msg
    end
end

local function updatePlayerPositionBehind(npc, distance)
    if not npc or not npc.Parent then return false end
    
    local targetRoot = npc:FindFirstChild("HumanoidRootPart")
    if not targetRoot then return false end
    
    if not rootPart or not rootPart.Parent then return false end
    
    local behindPosition = targetRoot.Position - targetRoot.CFrame.LookVector * distance
    rootPart.CFrame = CFrame.new(behindPosition)
    rootPart.CFrame = CFrame.lookAt(rootPart.Position, targetRoot.Position)
    
    return true
end

local function stopHeartbeat()
    if heartbeatConnection then
        heartbeatConnection:Disconnect()
        heartbeatConnection = nil
    end
end

local function stopStandFarm()
    standFarmMode = false
    currentTarget = nil
    stopHeartbeat()
    stopAttack()
end

-- ========== ФУНКЦИИ ФАРМА ==========

local function killLogicNormal(npc)
    if not npc or not npc.Parent then return false end
    
    stopHeartbeat()
    startAttack()
    
    heartbeatConnection = RunService.Heartbeat:Connect(function()
        if not ScriptActive or standFarmMode or not npc or not npc.Parent then
            return
        end
        
        if not character or not character:FindFirstChild("Humanoid") or character.Humanoid.Health <= 0 then
            return
        end
        
        updatePlayerPositionBehind(npc, 4)
    end)
    
    local startTime = tick()
    local npcDied = false
    
    while ScriptActive and not standFarmMode and npc and npc.Parent do
        local currentHealth = npc:FindFirstChild("Health")
        if not currentHealth or currentHealth.Value <= 0 then
            npcDied = true
            break
        end
        
        if not character or not character:FindFirstChild("Humanoid") or character.Humanoid.Health <= 0 then
            break
        end
        
        task.wait(0.1)
        
        if tick() - startTime > 30 then
            break
        end
    end
    
    stopHeartbeat()
    stopAttack()
    task.wait(0.2)
    
    return npcDied
end

local function killLogicWithStand(npc)
    if not npc or not npc.Parent then return false end
    
    local targetRoot = npc:FindFirstChild("HumanoidRootPart")
    if not targetRoot then return false end
    
    if statusText then
        statusText.Text = "⚔️ Attacking " .. npc.Name .. " with stand..."
    end
    
    stopHeartbeat()
    startAttack()
    
    local standMorph = getStandMorph()
    if standMorph then
        local standPosition = targetRoot.Position
        standMorph:SetPrimaryPartCFrame(CFrame.new(standPosition))
    end
    
    heartbeatConnection = RunService.Heartbeat:Connect(function()
        if not ScriptActive or not standFarmMode or not npc or not npc.Parent then
            return
        end
        
        if not character or not character:FindFirstChild("Humanoid") or character.Humanoid.Health <= 0 then
            return
        end
        
        local targetHead = npc:FindFirstChild("Head")
        if targetHead then
            local abovePosition = targetHead.Position + Vector3.new(0, 16, 0)
            rootPart.CFrame = CFrame.new(abovePosition)
        end
        
        local currentStand = getStandMorph()
        if currentStand and npc and npc.Parent then
            local currentTargetRoot = npc:FindFirstChild("HumanoidRootPart")
            if currentTargetRoot then
                local standPosition = currentTargetRoot.Position - currentTargetRoot.CFrame.LookVector * 3
                currentStand:SetPrimaryPartCFrame(CFrame.new(standPosition))
            end
        end
    end)
    
    local startTime = tick()
    local npcDied = false
    local lastHealth = nil
    
    while ScriptActive and standFarmMode and npc and npc.Parent do
        local currentHealth = npc:FindFirstChild("Health")
        if not currentHealth or currentHealth.Value <= 0 then
            npcDied = true
            if statusText then
                statusText.Text = "💀 " .. npc.Name .. " defeated!"
            end
            break
        end
        
        if lastHealth ~= currentHealth.Value and tick() % 1 < 0.1 then
            lastHealth = currentHealth.Value
            if statusText then
                statusText.Text = "❤️ " .. npc.Name .. " HP: " .. lastHealth
            end
        end
        
        if not character or not character:FindFirstChild("Humanoid") or character.Humanoid.Health <= 0 then
            if statusText then
                statusText.Text = "💀 Player died during combat!"
            end
            break
        end
        
        if tick() % 2 < 0.1 then
            if not hasStand() then
                if statusText then
                    statusText.Text = "⚠️ Stand lost during combat, resummoning..."
                end
                toggleStand()
                task.wait(1)
                if hasStand() then
                    local currentTargetRoot = npc:FindFirstChild("HumanoidRootPart")
                    if currentTargetRoot then
                        local newStand = getStandMorph()
                        if newStand then
                            local standPosition = currentTargetRoot.Position - currentTargetRoot.CFrame.LookVector * 3
                            newStand:SetPrimaryPartCFrame(CFrame.new(standPosition))
                        end
                    end
                end
            end
        end
        
        task.wait(0.2)
        
        if tick() - startTime > 60 then
            if statusText then
                statusText.Text = "⏰ Combat timeout for " .. npc.Name
            end
            break
        end
    end
    
    stopHeartbeat()
    stopAttack()
    task.wait(0.2)
    
    return npcDied
end

local function farmNPCs(npcName, neededCount)
    if not ScriptActive then return end
    
    local killedCount = 0
    if statusText then
        statusText.Text = "⚔️ Farming " .. npcName .. ": 0/" .. neededCount
    end
    
    while killedCount < neededCount and ScriptActive and not standFarmMode do
        if not character or not character:FindFirstChild("Humanoid") or character.Humanoid.Health <= 0 then
            if statusText then
                statusText.Text = "💀 Waiting for respawn..."
            end
            character = player.CharacterAdded:Wait()
            rootPart = character:WaitForChild("HumanoidRootPart")
            RE = character:WaitForChild("RemoteEvent")
            RF = character:WaitForChild("RemoteFunction")
            
            if ScriptActive then
                stopAttack()
                task.wait(1)
            end
            task.wait(2)
        end
        
        local target = findAliveNPC(npcName)
        
        if target then
            travelTo(target.HumanoidRootPart.Position)
            task.wait(0.3)
            
            if not ScriptActive then break end
            
            local npcDied = killLogicNormal(target)
            
            if npcDied then
                killedCount = killedCount + 1
                if statusText then
                    statusText.Text = "⚔️ Farming " .. npcName .. ": " .. killedCount .. "/" .. neededCount
                end
            end
            task.wait(0.5)
        else
            if statusText then
                statusText.Text = "⏳ Waiting for spawn: " .. npcName
            end
            task.wait(3)
        end
    end
end

local function startStandFarming()
    while ScriptActive do
        local stats = player:FindFirstChild("PlayerStats")
        if not stats then task.wait(2) continue end
        
        local standVal = stats:FindFirstChild("Stand")
        if not standVal then task.wait(2) continue end
        
        local currentStand = standVal.Value

        if currentStand ~= "None" then
            if unwantedStands[currentStand] then
                if statusText then
                    statusText.Text = "🔄 Bad stand, resetting..."
                end
                local hasRoka = player.Backpack:FindFirstChild("Rokakaka") or (player.Character and player.Character:FindFirstChild("Rokakaka"))
                
                if not hasRoka then
                    farmItem("Rokakaka")
                end
                
                useRoka()
                
                local elapsed = 0
                while standVal.Value ~= "None" and elapsed < 20 and ScriptActive do
                    task.wait(1)
                    elapsed = elapsed + 1
                end
                task.wait(4)
            else
                if statusText then
                    statusText.Text = "✅ Good stand: " .. currentStand
                end
                toggleStand()
                
                if statusText then
                    statusText.Text = "🔄 Resetting character to fix stand summon..."
                end
                
                local humanoid = character:FindFirstChild("Humanoid")
                if humanoid then
                    humanoid.Health = 0
                end
                stopAttack()
                
                character = player.CharacterAdded:Wait()
                rootPart = character:WaitForChild("HumanoidRootPart")
                RE = character:WaitForChild("RemoteEvent")
                RF = character:WaitForChild("RemoteFunction")
                
                local respawnAttempts = 0
                local respawnSuccess = false
                
                while not respawnSuccess and ScriptActive do
                    respawnAttempts = respawnAttempts + 1
                    if statusText then
                        statusText.Text = "🔄 Summoning stand after respawn (attempt " .. respawnAttempts .. ")..."
                    end
                    
                    toggleStand()
                    task.wait(2)
                    
                    if hasStand() then
                        respawnSuccess = true
                        if statusText then
                            statusText.Text = "✅ Stand summoned successfully after respawn!"
                        end
                    else
                        if statusText then
                            statusText.Text = "⚠️ Failed to summon after respawn, retrying..."
                        end
                        task.wait(1)
                    end
                end
                
                if not respawnSuccess then
                    if statusText then
                        statusText.Text = "❌ Cannot summon stand after respawn, giving up..."
                    end
                    return nil
                end
                
                if statusText then
                    statusText.Text = "✅ Character respawned, ready to use stand!"
                end
                
                return currentStand
            end
        else
            if statusText then
                statusText.Text = "📚 Learning skills..."
            end
            learnSkills()
            
            local hasArrow = player.Backpack:FindFirstChild("Mysterious Arrow") or (player.Character and player.Character:FindFirstChild("Mysterious Arrow"))
            
            if not hasArrow then
                if statusText then
                    statusText.Text = "🏹 Farming arrow..."
                end
                farmItem("Mysterious Arrow")
            end
            if statusText then
                statusText.Text = "✨ Using arrow..."
            end
            
            useArrow()
            
            local elapsed = 0
            while standVal.Value == "None" and elapsed < 30 and ScriptActive do
                task.wait(1)
                elapsed = elapsed + 1
            end
            task.wait(2)
        end
        task.wait(2)
    end
end

local function farmWithStand(npcName, neededCount)
    if not ScriptActive then return end
    
    local killedCount = 0
    standFarmMode = true
    if statusText then
        statusText.Text = "🤖 Stand farm " .. npcName .. ": 0/" .. neededCount
    end
    
    local standMorph = nil
    local summonAttempts = 0
    
    while not standMorph and ScriptActive and standFarmMode do
        summonAttempts = summonAttempts + 1
        if statusText then
            statusText.Text = "🔄 Summoning stand (attempt " .. summonAttempts .. ")..."
        end
        
        toggleStand()
        task.wait(2)
        
        standMorph = getStandMorph()
        
        if not standMorph then
            if statusText then
                statusText.Text = "⚠️ Failed to summon stand, retrying..."
            end
            task.wait(1)
        end
    end
    
    if not standMorph then
        if statusText then
            statusText.Text = "❌ Cannot summon stand at all, stopping..."
        end
        standFarmMode = false
        return
    end
    
    if statusText then
        statusText.Text = "✅ Stand summoned successfully!"
    end
    
    if not isAttacking then
        startAttack()
    end
    
    while killedCount < neededCount and ScriptActive and standFarmMode do
        if not hasStand() then
            if statusText then
                statusText.Text = "🔄 Stand lost, resummoning..."
            end
            
            local resummonAttempts = 0
            local resummonSuccess = false
            
            while not resummonSuccess and ScriptActive and standFarmMode do
                resummonAttempts = resummonAttempts + 1
                if statusText then
                    statusText.Text = "🔄 Resummoning stand (attempt " .. resummonAttempts .. ")..."
                end
                
                toggleStand()
                task.wait(2)
                
                if hasStand() then
                    resummonSuccess = true
                    standMorph = getStandMorph()
                    if statusText then
                        statusText.Text = "✅ Stand resummoned successfully!"
                    end
                else
                    if statusText then
                        statusText.Text = "⚠️ Failed to resummon, retrying..."
                    end
                    task.wait(1)
                end
            end
            
            if not resummonSuccess then
                if statusText then
                    statusText.Text = "❌ Cannot resummon stand, stopping..."
                end
                standFarmMode = false
                break
            end
        end
        
        if not character or not character:FindFirstChild("Humanoid") or character.Humanoid.Health <= 0 then
            if statusText then
                statusText.Text = "💀 Waiting for respawn..."
            end
            character = player.CharacterAdded:Wait()
            rootPart = character:WaitForChild("HumanoidRootPart")
            RE = character:WaitForChild("RemoteEvent")
            RF = character:WaitForChild("RemoteFunction")
            
            if ScriptActive and standFarmMode then
                stopAttack()
                task.wait(0.3)
                
                local respawnSummonAttempts = 0
                local respawnSummonSuccess = false
                
                while not respawnSummonSuccess and ScriptActive and standFarmMode do
                    respawnSummonAttempts = respawnSummonAttempts + 1
                    if statusText then
                        statusText.Text = "🔄 Summoning stand after respawn (attempt " .. respawnSummonAttempts .. ")..."
                    end
                    
                    toggleStand()
                    task.wait(2)
                    
                    if hasStand() then
                        respawnSummonSuccess = true
                        standMorph = getStandMorph()
                        if statusText then
                            statusText.Text = "✅ Stand summoned after respawn!"
                        end
                    else
                        if statusText then
                            statusText.Text = "⚠️ Failed to summon after respawn, retrying..."
                        end
                        task.wait(1)
                    end
                end
                
                if not respawnSummonSuccess then
                    if statusText then
                        statusText.Text = "❌ Cannot summon stand after respawn, stopping..."
                    end
                    standFarmMode = false
                    break
                end
                
                startAttack()
                standMorph = getStandMorph()
            end
            task.wait(1)
        end
        
        local target = findAliveNPC(npcName)
        
        if target then
            currentTarget = target
            
            if statusText then
                statusText.Text = "🎯 Found " .. npcName .. ", engaging..."
            end
            
            local targetRoot = target:FindFirstChild("HumanoidRootPart")
            if targetRoot then
                travelTo(targetRoot.Position)
                task.wait(0.5)
            end
            
            local targetDied = killLogicWithStand(target)
            
            if targetDied then
                killedCount = killedCount + 1
                if statusText then
                    statusText.Text = "✅ " .. npcName .. " defeated! (" .. killedCount .. "/" .. neededCount .. ")"
                end
            else
                if statusText then
                    statusText.Text = "⚠️ Failed to defeat " .. npcName .. ", retrying..."
                end
            end
            
            task.wait(1)
        else
            if statusText then
                statusText.Text = "⏳ Waiting for " .. npcName .. " to spawn..."
            end
            task.wait(3)
        end
    end
    
    stopStandFarm()
    
    if killedCount >= neededCount and statusText then
        statusText.Text = "✅ Stand farm completed: " .. npcName
    end
end

